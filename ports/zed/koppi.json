{
  "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
  "name": "koppi-theme",
  "author": "koppi",
  "themes": [
    {
      "name": "koppi-theme",
      "appearance": "dark",
      "style": {
        "background":            "#2e2e2e",
        "elevated.surface":      "#383838",
        "surface":               "#383838",
        "panel.background":      "#2e2e2e",
        "border":                "#535353",
        "border.variant":        "#434343",
        "border.focused":        "#d4b048",
        "border.selected":       "#d4b048",
        "border.transparent":    "#00000000",
        "border.disabled":       "#404040",

        "text":                  "#e8e8e8",
        "text.muted":            "#909090",
        "text.placeholder":      "#646464",
        "text.disabled":         "#646464",
        "text.accent":           "#d4b048",

        "icon":                  "#e8e8e8",
        "icon.muted":            "#909090",
        "icon.disabled":         "#646464",
        "icon.placeholder":      "#646464",
        "icon.accent":           "#d4b048",

        "status_bar.background": "#2e2e2e",
        "title_bar.background":  "#2e2e2e",
        "toolbar.background":    "#383838",
        "tab_bar.background":    "#2e2e2e",
        "tab.inactive_background": "#2e2e2e",
        "tab.active_background": "#383838",

        "editor.background":              "#2e2e2e",
        "editor.gutter.background":       "#2e2e2e",
        "editor.subheader.background":    "#383838",
        "editor.active_line.background":  "#383838",
        "editor.highlighted_line.background": "#353535",
        "editor.line_number":             "#4e4e4e",
        "editor.active_line_number":      "#909090",
        "editor.invisible":               "#4e4e4e",
        "editor.wrap_guide":              "#383838",
        "editor.active_wrap_guide":       "#434343",
        "editor.indent_guide":            "#3a3a3a",
        "editor.indent_guide_active":     "#535353",
        "editor.foreground":              "#e8e8e8",
        "editor.document_highlight.read_background":  "#434343",
        "editor.document_highlight.write_background": "#4e4e4e",

        "scrollbar.thumb.background":       "#535353",
        "scrollbar.thumb.hover_background": "#646464",
        "scrollbar.thumb.border":           "#535353",
        "scrollbar.track.background":       "#2e2e2e",
        "scrollbar.track.border":           "#383838",

        "element.background":       "#383838",
        "element.hover":            "#434343",
        "element.active":           "#4e4e4e",
        "element.selected":         "#434343",
        "element.disabled":         "#383838",
        "drop_target.background":   "#434343",

        "ghost_element.background": "#00000000",
        "ghost_element.hover":      "#383838",
        "ghost_element.active":     "#434343",
        "ghost_element.selected":   "#383838",
        "ghost_element.disabled":   "#646464",

        "link_text.hover":          "#f0d060",

        "selection.background":     "#4e4e4e",
        "search.match_background":  "#8a702055",

        "terminal.background":          "#2e2e2e",
        "terminal.foreground":          "#e8e8e8",
        "terminal.bright_foreground":   "#f5f5f5",
        "terminal.dim_foreground":      "#909090",
        "terminal.ansi.black":          "#2e2e2e",
        "terminal.ansi.red":            "#b54a4a",
        "terminal.ansi.green":          "#5a8f6a",
        "terminal.ansi.yellow":         "#d4b048",
        "terminal.ansi.blue":           "#646464",
        "terminal.ansi.magenta":        "#535353",
        "terminal.ansi.cyan":           "#909090",
        "terminal.ansi.white":          "#e8e8e8",
        "terminal.ansi.bright_black":   "#535353",
        "terminal.ansi.bright_red":     "#c45a5a",
        "terminal.ansi.bright_green":   "#6aa07a",
        "terminal.ansi.bright_yellow":  "#e8c858",
        "terminal.ansi.bright_blue":    "#909090",
        "terminal.ansi.bright_magenta": "#787878",
        "terminal.ansi.bright_cyan":    "#a8a8a8",
        "terminal.ansi.bright_white":   "#f5f5f5",

        "error":              "#c45a5a",
        "error.border":       "#c45a5a",
        "error.background":   "#c45a5a1a",
        "warning":            "#c4924a",
        "warning.border":     "#c4924a",
        "warning.background": "#c4924a1a",
        "info":               "#909090",
        "info.border":        "#909090",
        "success":            "#6aa07a",
        "success.border":     "#6aa07a",

        "hint":               "#787878",
        "hint.background":    "#383838",
        "predictive":         "#646464",

        "modified":  "#d4b048",
        "created":   "#6aa07a",
        "deleted":   "#c45a5a",
        "conflict":  "#c4924a",
        "hidden":    "#787878",
        "ignored":   "#646464",
        "renamed":   "#e8c858",

        "players": [
          { "cursor": "#d4b048", "background": "#d4b04830", "selection": "#d4b04830" }
        ],

        "syntax": {
          "attribute":              { "color": "#707070" },
          "boolean":                { "color": "#e8c858", "font_weight": 700 },
          "comment":                { "color": "#787878" },
          "comment.doc":            { "color": "#909090" },
          "constant":               { "color": "#e8c858" },
          "constructor":            { "color": "#e8c858" },
          "embedded":               { "color": "#d4b048" },
          "emphasis":               { "color": "#e8e8e8" },
          "emphasis.strong":        { "color": "#f5f5f5", "font_weight": 700 },
          "enum":                   { "color": "#d4b048" },
          "function":               { "color": "#f5f5f5" },
          "function.method":        { "color": "#f5f5f5" },
          "function.builtin":       { "color": "#909090" },
          "hint":                   { "color": "#787878" },
          "keyword":                { "color": "#f5f5f5", "font_weight": 700 },
          "label":                  { "color": "#d4b048" },
          "link_text":              { "color": "#d4b048" },
          "link_uri":               { "color": "#909090" },
          "number":                 { "color": "#f0d060" },
          "operator":               { "color": "#e8e8e8" },
          "predictive":             { "color": "#646464" },
          "preproc":                { "color": "#d4b048" },
          "primary":                { "color": "#e8e8e8" },
          "property":               { "color": "#e8e8e8" },
          "punctuation":            { "color": "#707070" },
          "punctuation.bracket":    { "color": "#707070" },
          "punctuation.delimiter":  { "color": "#707070" },
          "punctuation.list_marker":{ "color": "#d4b048" },
          "punctuation.special":    { "color": "#909090" },
          "string":                 { "color": "#d4b048" },
          "string.escape":          { "color": "#f0d060" },
          "string.regex":           { "color": "#f0d060" },
          "string.special":         { "color": "#f0d060" },
          "string.special.symbol":  { "color": "#e8c858" },
          "tag":                    { "color": "#e8c858" },
          "text.literal":           { "color": "#e8c858" },
          "title":                  { "color": "#f5f5f5", "font_weight": 700 },
          "type":                   { "color": "#d4b048" },
          "type.builtin":           { "color": "#d4b048" },
          "type.super":             { "color": "#d4b048" },
          "variable":               { "color": "#e8e8e8" },
          "variable.builtin":       { "color": "#d4b048" },
          "variable.member":        { "color": "#e8e8e8" },
          "variable.parameter":     { "color": "#e8e8e8" },
          "variant":                { "color": "#e8c858" }
        }
      }
    }
  ]
}
